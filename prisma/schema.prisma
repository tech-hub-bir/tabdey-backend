generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model admin_collaborators {
  collaborator_id BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  full_name       String    @db.VarChar(255)
  contact         String    @db.VarChar(20)
  email           String    @unique(map: "uniq_email") @db.VarChar(255)
  service         String?   @db.VarChar(255)
  role            String?   @db.VarChar(100)
  current_address String?   @db.VarChar(255)
  cid             String?   @unique(map: "uniq_cid") @db.VarChar(50)
  created_at      DateTime  @default(now()) @db.DateTime(0)
  updated_at      DateTime? @db.DateTime(0)

  @@index([role], map: "idx_role")
}

model admin_logs {
  log_id     BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt?  @db.UnsignedBigInt
  admin_name String   @db.VarChar(255)
  activity   String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)
  users      users?   @relation(fields: [user_id], references: [user_id], map: "fk_admin_logs_user")

  @@index([created_at], map: "idx_created_at")
  @@index([user_id], map: "idx_user_id")
}

model all_device_ids {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt   @unique(map: "uniq_user") @db.UnsignedBigInt
  device_id  String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)
  last_seen  DateTime @default(now()) @db.DateTime(0)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_all_device_ids_user")

  @@index([device_id], map: "idx_device_id")
}

model app_ratings {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt?  @db.UnsignedBigInt
  role         String?  @db.VarChar(50)
  rating       Int
  comment      String?  @db.Text
  platform     String?  @db.VarChar(20)
  os_version   String?  @db.VarChar(20)
  app_version  String?  @db.VarChar(50)
  device_model String?  @db.VarChar(255)
  network_type String?  @db.VarChar(50)
  created_at   DateTime @default(now()) @db.DateTime(0)
  users        users?   @relation(fields: [user_id], references: [user_id], map: "fk_app_rating_user")

  @@index([created_at], map: "idx_created_at")
  @@index([rating], map: "idx_rating")
  @@index([role], map: "idx_role")
  @@index([user_id], map: "idx_user_id")
}

model banners_base_prices {
  banner_price_id BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  amount_per_day  Decimal  @default(0.00) @db.Decimal(10, 2)
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @default(now()) @db.DateTime(0)
}

model bookings {
  id             String                  @id @db.VarChar(50)
  ticket_code    String                  @unique(map: "ticket_code") @db.VarChar(50)
  user_id        BigInt                  @db.UnsignedBigInt
  event_id       String                  @db.Char(36)
  tier_id        String                  @db.Char(36)
  quantity       Int
  total_amount   Int
  payment_method bookings_payment_method
  attendee_names String                  @db.LongText
  status         bookings_status         @default(confirmed)
  created_at     DateTime                @default(now()) @db.Timestamp(0)
  users          users                   @relation(fields: [user_id], references: [user_id], onUpdate: Restrict, map: "bookings_ibfk_1")
  events         events                  @relation(fields: [event_id], references: [id], onUpdate: Restrict, map: "bookings_ibfk_2")
  ticket_tiers   ticket_tiers            @relation(fields: [tier_id], references: [id], onUpdate: Restrict, map: "bookings_ibfk_3")

  @@index([event_id], map: "event_id")
  @@index([tier_id], map: "tier_id")
  @@index([user_id], map: "user_id")
}

model business_banners {
  id                        BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  business_id               BigInt                      @db.UnsignedBigInt
  title                     String?                     @db.VarChar(255)
  description               String?                     @db.Text
  banner_image              String?                     @db.VarChar(255)
  is_active                 Boolean                     @default(true)
  start_date                DateTime?                   @db.Date
  end_date                  DateTime?                   @db.Date
  owner_type                business_banners_owner_type
  created_at                DateTime                    @default(now()) @db.DateTime(0)
  updated_at                DateTime                    @default(now()) @db.DateTime(0)
  merchant_business_details merchant_business_details   @relation(fields: [business_id], references: [business_id], onDelete: Cascade, map: "business_banners_ibfk_1")

  @@index([business_id, owner_type, created_at], map: "idx_business_owner_created")
}

model business_types {
  id                      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  name                    String                    @unique(map: "uk_name") @db.VarChar(100)
  image                   String?                   @db.VarChar(255)
  types                   String?                   @db.VarChar(255)
  description             String?                   @db.Text
  created_at              DateTime                  @default(now()) @db.DateTime(0)
  updated_at              DateTime                  @default(now()) @db.DateTime(0)
  merchant_business_types merchant_business_types[]
}

model cancellation_rules {
  rule_id       Int                             @id @default(autoincrement())
  cancelled_by  cancellation_rules_cancelled_by
  ride_status   String                          @db.VarChar(50)
  stage         String                          @db.VarChar(50)
  fee_percent   Decimal                         @db.Decimal(5, 2)
  min_fee_cents Int
  max_fee_cents Int
  is_free       Boolean?                        @default(false)
  grace_minutes Int?
  description   String?                         @db.Text
  created_at    DateTime                        @default(now()) @db.Timestamp(0)
  updated_at    DateTime                        @default(now()) @db.Timestamp(0)
}

model cancelled_order_items {
  cancelled_item_id BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  order_id          String           @db.VarChar(12)
  business_id       Int
  business_name     String           @db.VarChar(255)
  menu_id           Int
  item_name         String           @db.VarChar(255)
  item_image        String?          @db.VarChar(500)
  quantity          Int              @default(1)
  price             Decimal          @db.Decimal(10, 2)
  subtotal          Decimal          @db.Decimal(10, 2)
  created_at        DateTime         @default(now()) @db.Timestamp(0)
  cancelled_orders  cancelled_orders @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_cancelled_items_order")

  @@index([business_id], map: "idx_cancelled_items_biz")
  @@index([order_id], map: "idx_cancelled_items_order")
}

model cancelled_orders {
  cancelled_id              BigInt                                  @id @default(autoincrement()) @db.UnsignedBigInt
  order_id                  String                                  @unique(map: "uk_cancelled_order_id") @db.VarChar(12)
  user_id                   Int
  status                    String                                  @default("CANCELLED") @db.VarChar(100)
  status_reason             String?                                 @db.VarChar(255)
  total_amount              Decimal                                 @default(0.00) @db.Decimal(10, 2)
  discount_amount           Decimal?                                @default(0.00) @db.Decimal(10, 2)
  delivery_fee              Decimal                                 @default(0.00) @db.Decimal(10, 2)
  platform_fee              Decimal                                 @default(0.00) @db.Decimal(10, 2)
  merchant_delivery_fee     Decimal?                                @db.Decimal(10, 2)
  payment_method            cancelled_orders_payment_method
  delivery_address          String                                  @db.VarChar(500)
  note_for_restaurant       String?                                 @db.VarChar(500)
  if_unavailable            String?                                 @db.VarChar(256)
  fulfillment_type          cancelled_orders_fulfillment_type?      @default(Delivery)
  priority                  Boolean?                                @default(false)
  estimated_arrivial_time   String?                                 @db.VarChar(40)
  cancelled_by              cancelled_orders_cancelled_by           @default(USER)
  cancelled_at              DateTime                                @default(now()) @db.Timestamp(0)
  original_created_at       DateTime?                               @db.Timestamp(0)
  original_updated_at       DateTime?                               @db.Timestamp(0)
  delivery_floor_unit       String?                                 @db.VarChar(80)
  delivery_instruction_note String?                                 @db.VarChar(256)
  delivery_photo_url        String?                                 @db.Text
  delivery_special_mode     cancelled_orders_delivery_special_mode?
  cancelled_order_items     cancelled_order_items[]

  @@index([cancelled_at], map: "idx_cancelled_time")
  @@index([user_id], map: "idx_cancelled_user")
}

model contact_messages {
  id            BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  full_name     String                        @db.VarChar(255)
  contact_type  contact_messages_contact_type @default(email)
  contact_value String                        @db.VarChar(255)
  user_type     String?                       @db.VarChar(100)
  message       String                        @db.Text
  status        contact_messages_status?      @default(new)
  created_at    DateTime                      @default(now()) @db.DateTime(0)
  updated_at    DateTime?                     @db.DateTime(0)

  @@index([contact_type], map: "idx_contact_type")
  @@index([created_at], map: "idx_created_at")
  @@index([status], map: "idx_status")
  @@index([user_type], map: "idx_user_type")
}

model delivered_order_items {
  delivered_item_id BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  order_id          String           @db.VarChar(12)
  business_id       Int
  business_name     String           @db.VarChar(255)
  menu_id           Int
  item_name         String           @db.VarChar(255)
  item_image        String?          @db.VarChar(500)
  quantity          Int              @default(1)
  price             Decimal          @db.Decimal(10, 2)
  subtotal          Decimal          @db.Decimal(10, 2)
  platform_fee      Decimal?         @default(0.00) @db.Decimal(10, 2)
  delivery_fee      Decimal?         @default(0.00) @db.Decimal(10, 2)
  created_at        DateTime         @default(now()) @db.Timestamp(0)
  delivered_orders  delivered_orders @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_delivered_items_order")

  @@index([business_id], map: "idx_delivered_items_biz")
  @@index([order_id], map: "idx_delivered_items_order")
}

model delivered_orders {
  delivered_id              BigInt                                  @id @default(autoincrement()) @db.UnsignedBigInt
  order_id                  String                                  @unique(map: "uk_delivered_order_id") @db.VarChar(12)
  user_id                   Int
  service_type              delivered_orders_service_type           @default(FOOD)
  status                    String                                  @default("COMPLETED") @db.VarChar(100)
  status_reason             String?                                 @db.VarChar(255)
  total_amount              Decimal                                 @default(0.00) @db.Decimal(10, 2)
  discount_amount           Decimal?                                @default(0.00) @db.Decimal(10, 2)
  delivery_fee              Decimal                                 @default(0.00) @db.Decimal(10, 2)
  platform_fee              Decimal                                 @default(0.00) @db.Decimal(10, 2)
  merchant_delivery_fee     Decimal?                                @db.Decimal(10, 2)
  payment_method            delivered_orders_payment_method
  delivery_address          String                                  @db.VarChar(500)
  note_for_restaurant       String?                                 @db.VarChar(500)
  if_unavailable            String?                                 @db.VarChar(256)
  fulfillment_type          delivered_orders_fulfillment_type?      @default(Delivery)
  priority                  Boolean?                                @default(false)
  estimated_arrivial_time   String?                                 @db.VarChar(40)
  delivered_by              delivered_orders_delivered_by           @default(SYSTEM)
  delivered_at              DateTime                                @default(now()) @db.Timestamp(0)
  delivery_batch_id         BigInt?                                 @db.UnsignedBigInt
  delivery_driver_id        Int?
  delivery_status           delivered_orders_delivery_status        @default(DELIVERED)
  delivery_ride_id          BigInt?
  original_created_at       DateTime?                               @db.Timestamp(0)
  original_updated_at       DateTime?                               @db.Timestamp(0)
  delivery_floor_unit       String?                                 @db.VarChar(80)
  delivery_instruction_note String?                                 @db.VarChar(256)
  delivery_photo_url        String?                                 @db.Text
  delivery_special_mode     delivered_orders_delivery_special_mode?
  delivered_order_items     delivered_order_items[]

  @@index([service_type, original_created_at], map: "idx_delivered_service_created")
  @@index([delivered_at], map: "idx_delivered_time")
  @@index([user_id], map: "idx_delivered_user")
}

model delivery_batches {
  batch_id           BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  merchant_id        Int
  driver_id          Int?
  ride_id            BigInt?
  status             delivery_batches_status @default(forming)
  total_orders       Int                     @default(0)
  created_at         DateTime                @default(now()) @db.DateTime(0)
  assigned_at        DateTime?               @db.DateTime(0)
  picked_up_at       DateTime?               @db.DateTime(0)
  completed_at       DateTime?               @db.DateTime(0)
  assigned_driver_id BigInt?                 @db.UnsignedBigInt
  city_id            String?                 @db.VarChar(64)
  pickup_lat         Float?
  pickup_lng         Float?
  pickup_place       String?                 @db.VarChar(255)
  metadata           String?                 @db.LongText
  updated_at         DateTime                @default(now()) @db.DateTime(0)
  drivers            drivers?                @relation(fields: [assigned_driver_id], references: [driver_id], map: "fk_db_assigned_driver")
  delivery_drops     delivery_drops[]
  order_items        order_items[]

  @@index([assigned_driver_id], map: "fk_db_assigned_driver")
}

model delivery_drops {
  drop_id               BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  batch_id              BigInt                @db.UnsignedBigInt
  ride_id               BigInt                @db.UnsignedBigInt
  seq                   Int
  order_id              String?               @db.VarChar(128)
  user_id               BigInt?               @db.UnsignedBigInt
  lat                   Float
  lng                   Float
  address               String?               @db.VarChar(512)
  amount_cents          Int                   @default(0) @db.UnsignedInt
  delivery_fee_cents    Int                   @default(0) @db.UnsignedInt
  platform_fee_cents    Int                   @default(0) @db.UnsignedInt
  cash_to_collect_cents Int                   @default(0) @db.UnsignedInt
  status                delivery_drops_status @default(pending)
  assigned_at           DateTime?             @db.DateTime(0)
  completed_at          DateTime?             @db.DateTime(0)
  created_at            DateTime              @default(now()) @db.DateTime(0)
  delivery_batches      delivery_batches      @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dd_batch")
  rides                 rides                 @relation(fields: [ride_id], references: [ride_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dd_ride")

  @@index([ride_id], map: "fk_dd_ride")
  @@index([batch_id, seq], map: "idx_batch_seq")
  @@index([batch_id, status], map: "idx_batch_status")
}

model driver_adjustments {
  adj_id       BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  driver_id    BigInt                  @db.UnsignedBigInt
  ride_id      BigInt?                 @db.UnsignedBigInt
  type         driver_adjustments_type
  amount_cents Int
  currency     String                  @default("BTN") @db.Char(3)
  meta_json    String?                 @db.LongText
  created_at   DateTime                @default(now()) @db.Timestamp(0)
  drivers      drivers                 @relation(fields: [driver_id], references: [driver_id], map: "fk_da_driver")
  rides        rides?                  @relation(fields: [ride_id], references: [ride_id], map: "fk_da_ride")

  @@index([driver_id, created_at], map: "idx_driver_date")
  @@index([ride_id], map: "idx_ride")
}

model driver_devices {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt    @db.UnsignedBigInt
  device_id  String    @db.VarChar(255)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Restrict, map: "driver_devices_ibfk_1")

  @@unique([user_id, device_id], map: "unique_driver_device")
}

model driver_documents {
  document_id         BigInt                                @id @default(autoincrement()) @db.UnsignedBigInt
  driver_id           BigInt                                @db.UnsignedBigInt
  document_type       driver_documents_document_type
  document_url        String                                @db.VarChar(255)
  verification_status driver_documents_verification_status? @default(pending)
  uploaded_at         DateTime?                             @default(now()) @db.Timestamp(0)
  verified_at         DateTime?                             @db.Timestamp(0)
  verified_by         BigInt?                               @db.UnsignedBigInt
  metadata            String?                               @db.LongText
  drivers             drivers                               @relation(fields: [driver_id], references: [driver_id], onDelete: Cascade, onUpdate: Restrict, map: "driver_documents_ibfk_1")

  @@index([document_type], map: "document_type")
  @@index([driver_id], map: "driver_id")
  @@index([verification_status], map: "verification_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model driver_earnings {
  earning_id      BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  driver_id       BigInt   @db.UnsignedBigInt
  ride_id         BigInt   @db.UnsignedBigInt
  base_fare_cents Int      @default(0) @db.UnsignedInt
  time_cents      Int      @default(0) @db.UnsignedInt
  tips_cents      Int      @default(0) @db.UnsignedInt
  currency        String   @default("BTN") @db.Char(3)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @db.Timestamp(0)
  payment_method  String?  @db.VarChar(20)
  drivers         drivers  @relation(fields: [driver_id], references: [driver_id], map: "fk_de_driver")
  rides           rides    @relation(fields: [ride_id], references: [ride_id], map: "fk_de_ride")

  @@unique([driver_id, ride_id], map: "uniq_driver_ride")
  @@index([payment_method], map: "idx_de_payment_method")
  @@index([driver_id], map: "idx_driver")
  @@index([payment_method], map: "idx_payment_method")
  @@index([ride_id], map: "idx_ride")
}

model driver_locations {
  id          BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  driver_id   BigInt               @db.UnsignedBigInt
  loc         Unsupported("point")
  recorded_at DateTime?            @default(now()) @db.Timestamp(0)
  drivers     drivers              @relation(fields: [driver_id], references: [driver_id], onUpdate: Restrict, map: "driver_locations_ibfk_1")

  @@index([driver_id], map: "driver_id")
}

model driver_vehicles {
  vehicle_id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  driver_id          BigInt    @db.UnsignedBigInt
  make               String    @db.VarChar(50)
  model              String    @db.VarChar(50)
  year               Int       @db.UnsignedSmallInt
  color              String    @db.VarChar(30)
  license_plate      String    @unique(map: "license_plate") @db.VarChar(20)
  vehicle_type       String    @db.VarChar(20)
  is_approved        Boolean?  @default(false)
  actual_capacity    Int?      @default(0) @db.UnsignedInt
  available_capacity Int?      @default(0) @db.UnsignedInt
  features           String?   @db.VarChar(255)
  insurance_expiry   DateTime? @db.Date
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  updated_at         DateTime? @default(now()) @db.Timestamp(0)
  code               String?   @db.VarChar(64)
  drivers            drivers   @relation(fields: [driver_id], references: [driver_id], onDelete: Cascade, onUpdate: Restrict, map: "driver_vehicles_ibfk_1")

  @@index([driver_id], map: "driver_id")
  @@index([is_approved], map: "is_approved")
  @@index([vehicle_type], map: "vehicle_type")
}

model drivers {
  driver_id                   BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                     BigInt?                  @unique(map: "user_id") @db.UnsignedBigInt
  license_number              String                   @unique(map: "license_number") @db.VarChar(50)
  license_expiry              DateTime                 @db.Date
  is_approved                 Boolean?                 @default(false)
  approval_status             drivers_approval_status? @default(pending)
  approved_at                 DateTime?                @db.Timestamp(0)
  rejection_reason            String?                  @db.Text
  rating                      Decimal?                 @default(0.00) @db.Decimal(3, 2)
  total_rides                 Int?                     @default(0) @db.UnsignedInt
  is_online                   Boolean?                 @default(false)
  current_location            Unsupported("point")
  current_location_updated_at DateTime?                @db.Timestamp(0)
  created_at                  DateTime?                @default(now()) @db.Timestamp(0)
  updated_at                  DateTime?                @default(now()) @db.Timestamp(0)
  delivery_batches            delivery_batches[]
  driver_adjustments          driver_adjustments[]
  driver_documents            driver_documents[]
  driver_earnings             driver_earnings[]
  driver_locations            driver_locations[]
  driver_vehicles             driver_vehicles[]
  users                       users?                   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Restrict, map: "drivers_ibfk_1")
  platform_levies             platform_levies[]
  ride_bookings               ride_bookings[]
  ride_ratings                ride_ratings[]
  ride_tips                   ride_tips[]
  rides                       rides[]

  @@index([approval_status], map: "approval_status")
  @@index([current_location(length: 32)], map: "current_location")
  @@index([is_online], map: "is_online")
}

model event_banners {
  id         String                  @id @db.Char(36)
  title      String                  @db.VarChar(255)
  subtitle   String?                 @db.VarChar(255)
  image_url  String                  @db.VarChar(500)
  link_type  event_banners_link_type @default(event)
  link_id    String?                 @db.VarChar(100)
  link_url   String?                 @db.VarChar(500)
  is_active  Boolean                 @default(true)
  sort_order Int                     @default(0)
  created_at DateTime                @default(now()) @db.Timestamp(0)
}

model event_booking_seats {
  booking_id       String            @db.VarChar(50)
  seat_id          String            @db.Char(36)
  event_id         String            @db.Char(36)
  screening_id     String?           @db.Char(36)
  event_screenings event_screenings? @relation(fields: [screening_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "bs_ibfk_screening")
  event_bookings   event_bookings    @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "event_booking_seats_ibfk_1")
  event_seats      event_seats       @relation(fields: [seat_id], references: [id], onUpdate: Restrict, map: "event_booking_seats_ibfk_2")
  events           events            @relation(fields: [event_id], references: [id], onUpdate: Restrict, map: "event_booking_seats_ibfk_3")

  @@id([booking_id, seat_id])
  @@index([event_id], map: "event_id")
  @@index([screening_id], map: "idx_bs_screening")
  @@index([seat_id], map: "seat_id")
}

model event_bookings {
  id                  String                        @id @db.VarChar(50)
  ticket_code         String                        @unique(map: "ticket_code") @db.VarChar(50)
  user_id             BigInt                        @db.UnsignedBigInt
  event_id            String                        @db.Char(36)
  screening_id        String?                       @db.Char(36)
  tier_id             String                        @db.Char(36)
  quantity            Int
  total_amount        Int
  payment_method      event_bookings_payment_method
  attendee_names      String                        @db.LongText
  status              event_bookings_status         @default(confirmed)
  payment_status      event_bookings_payment_status @default(paid)
  wallet_journal_code String?                       @db.VarChar(36)
