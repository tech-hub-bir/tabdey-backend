  user_agent       String?  @db.VarChar(255)
  created_at       DateTime @default(now()) @db.Timestamp(0)

  @@index([action, status], map: "idx_wtl_action_status")
  @@index([created_at], map: "idx_wtl_created_at")
  @@index([journal_code], map: "idx_wtl_journal_code")
  @@index([transaction_id], map: "idx_wtl_transaction_id")
  @@index([user_id], map: "idx_wtl_user_id")
  @@index([wallet_id], map: "idx_wtl_wallet_id")
  @@index([request_id], map: "idx_wtl_request_id")
}

